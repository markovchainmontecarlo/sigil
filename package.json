{
  "name": "sigil",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "CLI and TypeScript toolkit for repository workflows, static YAML workflows, and TypeScript sigils over configured agents",
  "license": "MIT",
  "types": "./src/index.ts",
  "files": [
    "LICENSE",
    "bun.lock",
    "package.json",
    "src",
    "skills",
    "man"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@agentclientprotocol/codex-acp": "^1.1.2",
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@github/copilot-sdk": "^1.0.5",
    "@mastra/acp": "^0.3.0",
    "@mastra/claude": "^0.3.0",
    "@mastra/core": "^1.49.0",
    "@mastra/libsql": "^1.15.0",
    "yaml": "^2.8.1",
    "zod": "^4.0.0"
  },
  "scripts": {
    "cli": "bun src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "preview:readme": "node scripts/preview-readme.mjs --serve",
    "smoke:distribution": "bash scripts/distribution-smoke.sh",
    "smoke:agents": "node scripts/smoke-agents.mjs",
    "demo:review": "node test/demo-review.mjs"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "bin": {
    "sigil": "src/cli.ts"
  }
}
