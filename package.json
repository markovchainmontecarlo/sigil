{
  "name": "sigil",
  "version": "0.14.0",
  "private": true,
  "type": "module",
  "description": "CLI and TypeScript toolkit for repository workflows, static YAML workflows, and TypeScript sigils over configured agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/markovchainmontecarlo/sigil.git"
  },
  "bugs": {
    "url": "https://github.com/markovchainmontecarlo/sigil/issues"
  },
  "homepage": "https://github.com/markovchainmontecarlo/sigil#readme",
  "types": "./dist/package/src/index.d.ts",
  "files": [
    "dist/package"
  ],
  "exports": {
    ".": {
      "types": "./dist/package/src/index.d.ts",
      "import": "./dist/package/src/index.js"
    },
    "./contracts": {
      "types": "./dist/package/src/contracts-entry.d.ts",
      "import": "./dist/package/src/contracts-entry.js"
    },
    "./server": {
      "types": "./dist/package/src/server-entry.d.ts",
      "import": "./dist/package/src/server-entry.js"
    }
  },
  "dependencies": {
    "@agentclientprotocol/codex-acp": "^1.1.2",
    "@agentclientprotocol/sdk": "^0.21.0",
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@github/copilot-sdk": "^1.0.5",
    "@mastra/acp": "^0.3.0",
    "@mastra/claude": "^0.3.0",
    "@mastra/core": "^1.49.0",
    "@mastra/libsql": "^1.15.0",
    "yaml": "^2.8.1",
    "zod": "^4.0.0"
  },
  "scripts": {
    "cli": "bun src/cli.ts",
    "clean": "rm -rf dist/package",
    "build": "bun scripts/build-package.ts",
    "test:package": "bun test test/package-build.test.ts",
    "verify:package": "node --experimental-strip-types scripts/verify-package.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:all",
    "test:fast": "bun scripts/test-suite.ts fast",
    "test:integration": "bun scripts/test-suite.ts integration",
    "test:all": "bun run test:fast && bun run test:integration",
    "validate:release": "bun run typecheck && bun run test:all && bun run verify:package",
    "preview:readme": "node scripts/preview-readme.mjs --serve",
    "smoke:distribution": "bash scripts/distribution-smoke.sh",
    "smoke:agents": "node scripts/smoke-agents.mjs",
    "smoke:claude-subscription": "bun scripts/smoke-claude-subscription.mjs",
    "demo:review": "node test/demo-review.mjs"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  },
  "bin": {
    "sigil": "dist/package/src/cli.js"
  }
}
