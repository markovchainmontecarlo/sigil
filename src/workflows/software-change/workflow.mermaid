flowchart TD
  Input["softwareChange input"]
  TaskFile{"taskFile supplied?"}
  ExistingGraph["read supplied task graph"]
  SuppliedGraphValid{"supplied task graph valid?"}
  SuppliedGraphFailure["terminal workflow error: invalid supplied task graph"]
  Result["SoftwareChangeResult"]
  Delivery["delivery boundary: returns branch and PR body only"]

  Input --> TaskFile
  TaskFile -->|yes| ExistingGraph
  TaskFile -->|no| PlanConfig
  ExistingGraph --> SuppliedGraphValid
  SuppliedGraphValid -->|valid| LoadGraph
  SuppliedGraphValid -->|invalid| SuppliedGraphFailure

  subgraph Planning["planning stage"]
    PlanConfig["load config and repository context"]
    Planners["configured planner roles run in parallel"]
    PlannerArtifacts["planner markdown artifacts"]
    AnyPlan{"usable planner output?"}
    Synthesizer["configured synthesizer role"]
    MultiplePlans{"more than one planner output?"}
    SinglePlan["use single planner output directly"]
    Compare["compare plans and build requirements crosswalk"]
    VerifyClaims["verify claims, interfaces, and requirement coverage"]
    Resolve["resolve verified divergences"]
    BuildGraph["build typed task graph artifact"]
    Enrich["enrich task graph"]
    RepairGraph["repair and deterministically validate task graph"]
    CloseSynthesis["close synthesis session"]
    PlanningReview["fresh configured semantic reviewer"]
    ReviewValid{"semantic review valid?"}
    ReviewRepair["fresh synthesizer repairs typed findings"]
    ReviewLimit{"semantic repair limit exhausted?"}
    PlanResult["PlanResult"]

    PlanConfig --> Planners
    Planners --> PlannerArtifacts
    PlannerArtifacts --> AnyPlan
    AnyPlan -->|no| PlanResult
    AnyPlan -->|yes| Synthesizer
    Synthesizer --> MultiplePlans
    MultiplePlans -->|no| SinglePlan
    MultiplePlans -->|yes| Compare
    SinglePlan --> BuildGraph
    Compare --> VerifyClaims
    VerifyClaims --> Resolve
    Resolve --> BuildGraph
    BuildGraph --> Enrich
    Enrich --> RepairGraph
    RepairGraph --> CloseSynthesis
    CloseSynthesis --> PlanningReview
    PlanningReview --> ReviewValid
    ReviewValid -->|yes| PlanResult
    ReviewValid -->|no| ReviewLimit
    ReviewLimit -->|no| ReviewRepair
    ReviewRepair --> RepairGraph
    ReviewLimit -->|yes| PlanResult
  end

  PlanResult --> PlanValid{"planning result valid?"}
  PlanValid -->|no| Result
  PlanValid -->|yes| LoadGraph

  subgraph Implementation["implementation stage"]
    LoadGraph["load and canonically persist typed task graph"]
    ImplementationCheckpoint["atomic implementation checkpoint bound to graph, branch, base, and baseline commit"]
    ResumeGate{"new run or verified resume?"}
    CleanGate{"target tree clean?"}
    CleanFailure["terminal workflow error: dirty target tree"]
    Branch["checkout fresh implementation branch"]
    BaselineGate{"establish configured baseline gates"}
    TaskLoop{"next pending task in deterministic runnable frontier"}
    DependencyGate{"dependencies completed?"}
    Running["checkpoint task running before prompt"]
    NewCoder{"new coder session?"}
    SessionContext["load graph context, current configured context, and checkpoint handoff"]
    ProviderInterruption{"provider interrupted?"}
    RecoveryBundle["preserve tracked and untracked recovery bundle"]
    Coder["configured coder role implements task"]
    TaskGate{"task command verification and configured build/test gates pass?"}
    TaskRepair["same coder repairs task"]
    CommitTask["commit task change"]
    CommitResult{"task commit result?"}
    TaskCommitIssue["record task commit failure issue"]
    NoChangeRepair["same coder repairs no-change task"]
    NoChangeGate{"configured build/test gates pass after no-change repair?"}
    RetryCommit["retry task commit"]
    RetryCommitResult{"retry commit result?"}
    RetryCommitIssue["record retry commit failure issue"]
    NoopVerdict["noop-check agent verdict"]
    ConsecutiveNoop{"two consecutive unsatisfied noop checks?"}
    StopWork["stop future task work"]
    ReplyArtifact["persist task reply artifact outside target tree"]
    Completed["checkpoint verified task commit as completed"]
    AllCompleted{"all checkpoint tasks completed?"}
    IncompleteResult["return incomplete result without final verification or review"]
    FinalGates{"baseline regression, e2e, verify gates"}
    FinalRepair["configured coder role repairs final gate failure"]
    ReviewStage["implementation-owned review stage"]
    ReviewCommit["commit review fixes"]
    StrongestGate{"strongest configured gate after review"}
    FinalRepairCommit["commit final gate repair"]
    FinalRepairCommitResult{"final repair commit result?"}
    FinalRepairCommitIssue["record final repair commit failure issue"]
    ImplementResult["ImplementResult"]

    LoadGraph --> ResumeGate
    ResumeGate -->|new| CleanGate
    ResumeGate -->|matching checkpoint| ImplementationCheckpoint
    CleanGate -->|clean| Branch
    CleanGate -->|dirty| CleanFailure
    Branch --> BaselineGate
    BaselineGate -->|red| ImplementResult
    BaselineGate -->|green| ImplementationCheckpoint
    ImplementationCheckpoint --> TaskLoop
    TaskLoop -->|task| DependencyGate
    DependencyGate -->|incomplete dependency: blocked| TaskLoop
    DependencyGate -->|ready| Running
    Running --> NewCoder
    NewCoder -->|yes| SessionContext
    NewCoder -->|no| Coder
    SessionContext --> Coder
    Coder --> ProviderInterruption
    ProviderInterruption -->|yes| RecoveryBundle
    RecoveryBundle --> IncompleteResult
    ProviderInterruption -->|no| TaskGate
    TaskGate -->|red, attempts remain| TaskRepair
    TaskRepair --> TaskGate
    TaskGate -->|red, exhausted| ReplyArtifact
    TaskGate -->|green| CommitTask
    CommitTask --> CommitResult
    CommitResult -->|committed| ReplyArtifact
    CommitResult -->|failed| TaskCommitIssue
    TaskCommitIssue --> ReplyArtifact
    CommitResult -->|nothing| NoChangeRepair
    NoChangeRepair --> NoChangeGate
    NoChangeGate -->|green| RetryCommit
    NoChangeGate -->|red| NoopVerdict
    RetryCommit --> RetryCommitResult
    RetryCommitResult -->|committed| ReplyArtifact
    RetryCommitResult -->|failed| RetryCommitIssue
    RetryCommitIssue --> ReplyArtifact
    RetryCommitResult -->|nothing| NoopVerdict
    NoopVerdict --> ConsecutiveNoop
    ConsecutiveNoop -->|no| ReplyArtifact
    ConsecutiveNoop -->|yes| StopWork
    StopWork --> ReplyArtifact
    ReplyArtifact --> Completed
    Completed --> TaskLoop
    TaskLoop -->|no runnable task| AllCompleted
    AllCompleted -->|no| IncompleteResult
    AllCompleted -->|yes| FinalGates
    FinalGates -->|red, attempts remain| FinalRepair
    FinalRepair --> FinalRepairCommit
    FinalRepairCommit --> FinalRepairCommitResult
    FinalRepairCommitResult -->|committed or no change| FinalGates
    FinalRepairCommitResult -->|failed| FinalRepairCommitIssue
    FinalRepairCommitIssue --> FinalGates
    FinalGates --> ReviewStage
    ReviewStage --> ReviewCommit
    ReviewCommit --> StrongestGate
    StrongestGate --> ImplementResult
  end

  ImplementResult --> Result
  Result -. "no publish, push, pull request, or merge; no dispatch policy" .-> Delivery

  classDef agent fill:#dbeafe,stroke:#2563eb,color:#172554;
  classDef gate fill:#fef3c7,stroke:#d97706,color:#451a03;
  classDef artifact fill:#ecfdf5,stroke:#059669,color:#064e3b;
  classDef boundary fill:#f3e8ff,stroke:#7c3aed,color:#3b0764;
  classDef failure fill:#fee2e2,stroke:#dc2626,color:#450a0a;
  class Planners,Synthesizer,PlanningReview,ReviewRepair,Coder,TaskRepair,NoChangeRepair,NoopVerdict,FinalRepair,ReviewStage agent;
  class TaskFile,SuppliedGraphValid,AnyPlan,MultiplePlans,ReviewValid,ReviewLimit,PlanValid,ResumeGate,CleanGate,BaselineGate,DependencyGate,NewCoder,ProviderInterruption,TaskGate,CommitResult,NoChangeGate,RetryCommitResult,ConsecutiveNoop,AllCompleted,FinalGates,FinalRepairCommitResult,StrongestGate gate;
  class PlannerArtifacts,BuildGraph,ImplementationCheckpoint,RecoveryBundle,ReplyArtifact,TaskCommitIssue,RetryCommitIssue,FinalRepairCommit,FinalRepairCommitIssue artifact;
  class Delivery boundary;
  class SuppliedGraphFailure,CleanFailure failure;
